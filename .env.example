# Resend API key (required in production)
RESEND_API_KEY=

# Contact inbox routing
CONTACT_TO_EMAIL=info@bbouwadvies.nl

# Sender identity used for outbound mail
CONTACT_FROM_EMAIL="B Bouwadvies <onboarding@resend.dev>"

# Optional fallback sender identity
RESEND_FROM_EMAIL=

# Public app URL used to build email CTA links
NEXT_PUBLIC_SITE_URL=https://bbouwadvies.nl

# WhatsApp floating contact CTA
# Format: country code + number (digits only), e.g. 31634369753
NEXT_PUBLIC_WHATSAPP_NUMBER=
# Set to false to disable CTA without code changes
NEXT_PUBLIC_WHATSAPP_ENABLED=true
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hallo! Ik heb een vraag over een bouwkundige inspectie of advies.
